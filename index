  Fairy: `<img src="https://raw.githubusercontent.com/partywhale/pokemon-type-icons/main/icons/fairy.svg" onerror="this.src='https://raw.githubusercontent.com/duiker101/pokemon-type-svg-icons/master/icons/fairy.svg'" width="20" height="20" alt="Fairy" style="display:inline-block;vertical-align:middle;filter:drop-shadow(0 1px 2px rgba(0,0,0,0.4))">`,
};

// State:
//   allActive=true  → show all pokemon (startup state, all buttons visually lit)
//   allActive=false → filter by activeTypes (empty = none, some = those types)
// On first type click, we leave allActive=false and start fresh from empty.
let allActive = true;
let userHasFiltered = false; // tracks if user has made any type selection
activeTypes = new Set(ALL_TYPES); // visually lit on startup, but allActive=true overrides filter

// Build type filter buttons
const tf = document.getElementById('typefilters');

const allBtn = document.createElement('button');
allBtn.className = 'ctrl-btn';
allBtn.id = 'btn-all';
allBtn.textContent = 'All';
allBtn.onclick = () => {
  allActive = true;
  userHasFiltered = false;
  activeTypes = new Set(ALL_TYPES);
  syncButtons();
  render();
};
tf.appendChild(allBtn);

const noneBtn = document.createElement('button');
noneBtn.className = 'ctrl-btn';
noneBtn.id = 'btn-none';
noneBtn.textContent = 'None';
noneBtn.onclick = () => {
  allActive = false;
  userHasFiltered = true;
  activeTypes = new Set();
  syncButtons();
  render();
};
tf.appendChild(noneBtn);

ALL_TYPES.forEach(t => {
  const c = TYPE_COLORS[t] || {bg:'#888',text:'#fff'};
  const icon = TYPE_ICONS[t] || '';
  const btn = document.createElement('button');
  btn.className = 'type-btn active';
  btn.innerHTML = icon + t;
  btn.style.background = c.bg;
  btn.style.color = c.text;
  btn.style.borderColor = c.bg;
  btn.dataset.type = t;
  btn.onclick = () => {
    if (!userHasFiltered) {
      // First interaction: start fresh with just this type
      userHasFiltered = true;
      allActive = false;
      activeTypes = new Set([t]);
    } else {
      // Subsequent clicks: toggle this type in/out
      allActive = false;
      if (activeTypes.has(t)) {
        activeTypes.delete(t);
      } else {
        activeTypes.add(t);
      }
    }
    syncButtons();
    render();
  };
  tf.appendChild(btn);
});

function syncButtons() {
  document.querySelectorAll('.type-btn').forEach(b => {
    const t = b.dataset.type;
    // When allActive, all buttons appear lit
    if (allActive || activeTypes.has(t)) {
      b.classList.add('active');
    } else {
      b.classList.remove('active');
    }
  });
}

function render() {
  const q = document.getElementById('search').value.toLowerCase().trim();
  const sort = document.getElementById('sort').value;

  let list = POKEMON.filter(p => {
    const nameOk = !q || p.name.toLowerCase().includes(q);
    const typeOk = allActive
      ? true
      : (activeTypes.size === 0 ? false : p.types.some(t => activeTypes.has(t)));
    return nameOk && typeOk;
  });

  if (sort === 'name') list.sort((a,b) => a.name.localeCompare(b.name));
  else if (sort === 'type') list.sort((a,b) => a.types[0].localeCompare(b.types[0]) || a.num - b.num);
  else list.sort((a,b) => a.num - b.num);

  const stats = document.getElementById('statsbar');
  stats.innerHTML = `<span>${list.length}</span> of ${POKEMON.length} Pokémon shown`;

  const grid = document.getElementById('grid');
  if (!list.length) {
    grid.innerHTML = '<div class="none-msg">No Pokémon match your filters.<br>Try adjusting your search.</div>';
    return;
  }

  grid.innerHTML = list.map(p => {
    const badges = p.types.map(t => {
      const c = TYPE_COLORS[t] || {bg:'#888',text:'#fff'};
      return `<span class="tbadge" style="background:${c.bg};color:${c.text}">${t}</span>`;
    }).join('');
    const url = serebiiUrl(p.name);
    const fallback = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/${p.num}.png`;
    return `<div class="card" onclick="window.open('${url}','_blank')" title="Open ${p.name} on Serebii">
      <img src="${imgUrl(p.num)}" alt="${p.name}" onerror="this.src='${fallback}'" loading="lazy">
      <div class="pname">${p.name}</div>
      <div class="pnum">#${String(p.num).padStart(3,'0')}</div>
      <div class="types">${badges}</div>
    </div>`;
  }).join('');
}

render();
</script>
