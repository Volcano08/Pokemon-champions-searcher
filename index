  Bug: `<img src="https://raw.githubusercontent.com/partywhale/pokemon-type-icons/main/icons/bug.svg" onerror="this.src='https://raw.githubusercontent.com/duiker101/pokemon-type-svg-icons/master/icons/bug.svg'" width="20" height="20" alt="Bug" style="display:inline-block;vertical-align:middle;filter:drop-shadow(0 1px 2px rgba(0,0,0,0.4))">`,
  Rock: `<img src="https://raw.githubusercontent.com/partywhale/pokemon-type-icons/main/icons/rock.svg" onerror="this.src='https://raw.githubusercontent.com/duiker101/pokemon-type-svg-icons/master/icons/rock.svg'" width="20" height="20" alt="Rock" style="display:inline-block;vertical-align:middle;filter:drop-shadow(0 1px 2px rgba(0,0,0,0.4))">`,
  Ghost: `<img src="https://raw.githubusercontent.com/partywhale/pokemon-type-icons/main/icons/ghost.svg" onerror="this.src='https://raw.githubusercontent.com/duiker101/pokemon-type-svg-icons/master/icons/ghost.svg'" width="20" height="20" alt="Ghost" style="display:inline-block;vertical-align:middle;filter:drop-shadow(0 1px 2px rgba(0,0,0,0.4))">`,
  Dragon: `<img src="https://raw.githubusercontent.com/partywhale/pokemon-type-icons/main/icons/dragon.svg" onerror="this.src='https://raw.githubusercontent.com/duiker101/pokemon-type-svg-icons/master/icons/dragon.svg'" width="20" height="20" alt="Dragon" style="display:inline-block;vertical-align:middle;filter:drop-shadow(0 1px 2px rgba(0,0,0,0.4))">`,
