  Flying: `<img src="https://raw.githubusercontent.com/partywhale/pokemon-type-icons/main/icons/flying.svg" onerror="this.src='https://raw.githubusercontent.com/duiker101/pokemon-type-svg-icons/master/icons/flying.svg'" width="20" height="20" alt="Flying" style="display:inline-block;vertical-align:middle;filter:drop-shadow(0 1px 2px rgba(0,0,0,0.4))">`,
